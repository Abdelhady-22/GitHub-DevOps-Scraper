# GitHub tokens (one per line, comma-separated)
# GITHUB_TOKENS=ghp_xxx,ghp_yyy

# OpenAI (only if provider=openai in scraper_config.yaml)
# OPENAI_API_KEY=sk-...

# Anthropic (only if provider=anthropic in scraper_config.yaml)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (only if using a remote Ollama instance)
# OLLAMA_BASE_URL=http://localhost:11434
