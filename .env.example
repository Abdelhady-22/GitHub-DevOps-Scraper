# GitHub tokens — comma-separated list of Personal Access Tokens
# Required: at least one token. More tokens = higher throughput (5k calls/hr each)
GITHUB_TOKENS=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (only if provider=openai in scraper_config.yaml)
# OPENAI_API_KEY=sk-...

# Anthropic (only if provider=anthropic in scraper_config.yaml)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (only if using a remote Ollama instance)
# OLLAMA_BASE_URL=http://localhost:11434
